{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://photonicbench.local/schemas/photonic-bench-comparison-export-v1.schema.json",
  "title": "PhotonicBench visualizer comparison export v1",
  "x-schema-version-policy": {
    "schema_identifier": "photonic-bench-comparison-export-v1",
    "compatible_changes": [
      "Add optional properties to existing objects.",
      "Add shared $defs that are only referenced by optional properties.",
      "Clarify descriptions, examples, or documentation without changing meaning."
    ],
    "breaking_changes": [
      "Add new required properties.",
      "Remove or rename existing properties.",
      "Change units, nullability, value type, or local-model versus published-reference semantics."
    ],
    "breaking_change_action": "Use a new schema_version string and a new schema file."
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "reports_dir",
    "pinned_id",
    "selected_artifact_ids",
    "analysis_focus",
    "filters",
    "url_state",
    "visible_artifact_ids",
    "recommendations",
    "modeling_boundaries",
    "boundary_notes",
    "artifacts",
    "grouped_metrics"
  ],
  "properties": {
    "schema_version": {
      "const": "photonic-bench-comparison-export-v1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "reports_dir": {
      "type": "string"
    },
    "pinned_id": {
      "type": ["string", "null"]
    },
    "selected_artifact_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "analysis_focus": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "label",
        "description",
        "metric_labels",
        "score_profile",
        "score_weights"
      ],
      "properties": {
        "key": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "metric_labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "score_profile": {
          "$ref": "#/$defs/scoreProfile"
        },
        "score_weights": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scoreWeight"
          }
        }
      }
    },
    "filters": {
      "$ref": "#/$defs/filterState"
    },
    "url_state": {
      "type": "string"
    },
    "visible_artifact_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/recommendation"
      }
    },
    "review_checklist": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reviewChecklistEntry"
      }
    },
    "modeling_boundaries": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "boundary_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifactSummary"
      }
    },
    "grouped_metrics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/groupedMetrics"
      }
    }
  },
  "$defs": {
    "nullableNumber": {
      "type": ["number", "null"]
    },
    "scoreWeight": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metric", "weight"],
      "properties": {
        "metric": {
          "type": "string"
        },
        "weight": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "scoreProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "label", "description", "is_builtin"],
      "properties": {
        "key": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "is_builtin": {
          "type": "boolean"
        }
      }
    },
    "filterState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "search",
        "schema",
        "boundary",
        "source_quality",
        "sort",
        "grouping"
      ],
      "properties": {
        "search": {
          "type": "string"
        },
        "schema": {
          "type": "string"
        },
        "boundary": {
          "type": "string"
        },
        "source_quality": {
          "type": "string"
        },
        "sort": {
          "type": "string"
        },
        "grouping": {
          "type": "string"
        }
      }
    },
    "recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "group",
        "artifact_id",
        "benchmark_name",
        "score",
        "best_use",
        "score_explanation"
      ],
      "properties": {
        "group": {
          "type": "string"
        },
        "artifact_id": {
          "type": "string"
        },
        "benchmark_name": {
          "type": "string"
        },
        "score": {
          "type": "number"
        },
        "best_use": {
          "type": "string"
        },
        "score_explanation": {
          "$ref": "#/$defs/scoreExplanation"
        }
      }
    },
    "reviewChecklistEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "label", "status", "value", "note"],
      "properties": {
        "key": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "status": {
          "enum": ["pass", "review", "missing", "n/a"]
        },
        "value": {
          "type": "string"
        },
        "note": {
          "type": "string"
        }
      }
    },
    "scoreExplanation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score", "total_weight", "components"],
      "properties": {
        "score": {
          "type": "number"
        },
        "total_weight": {
          "type": "number",
          "minimum": 0
        },
        "components": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scoreComponent"
          }
        }
      }
    },
    "scoreComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric",
        "direction",
        "raw_value",
        "formatted_value",
        "normalized_score",
        "weight",
        "contribution",
        "included"
      ],
      "properties": {
        "metric": {
          "type": "string"
        },
        "direction": {
          "type": "string"
        },
        "raw_value": {
          "$ref": "#/$defs/nullableNumber"
        },
        "formatted_value": {
          "type": "string"
        },
        "normalized_score": {
          "$ref": "#/$defs/nullableNumber"
        },
        "weight": {
          "type": "number",
          "minimum": 0
        },
        "contribution": {
          "$ref": "#/$defs/nullableNumber"
        },
        "included": {
          "type": "boolean"
        }
      }
    },
    "artifactSummary": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "kind", "benchmark_name", "source_path"],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "benchmark_name": {
          "type": "string"
        },
        "source_path": {
          "type": "string"
        },
        "local_compute_and_conversion_energy_share": {
          "$ref": "#/$defs/nullableNumber"
        },
        "movement_to_compute_energy_ratio": {
          "$ref": "#/$defs/nullableNumber"
        },
        "memory_scenario": {
          "type": ["string", "null"]
        },
        "contention_preset": {
          "type": ["string", "null"]
        },
        "contention_overlap_model": {
          "type": ["string", "null"]
        },
        "contention_only_loaded_bandwidth_bytes_per_ns": {
          "$ref": "#/$defs/nullableNumber"
        },
        "effective_usable_bandwidth_under_load_bytes_per_ns": {
          "$ref": "#/$defs/nullableNumber"
        },
        "guardbanded_usable_bandwidth_under_load_bytes_per_ns": {
          "$ref": "#/$defs/nullableNumber"
        },
        "guardbanded_loaded_hierarchy_bandwidth_bytes_per_ns": {
          "$ref": "#/$defs/nullableNumber"
        },
        "hierarchy_equivalent_ops_per_byte": {
          "$ref": "#/$defs/nullableNumber"
        },
        "movement_energy_per_hierarchy_byte_pj": {
          "$ref": "#/$defs/nullableNumber"
        },
        "dominant_traffic_tier": {
          "type": ["string", "null"]
        },
        "dominant_system_energy_component": {
          "type": ["string", "null"]
        },
        "dominant_movement_energy_tier": {
          "type": ["string", "null"]
        },
        "nominal_memory_bottleneck_tier": {
          "type": ["string", "null"]
        },
        "contention_memory_bottleneck_tier": {
          "type": ["string", "null"]
        },
        "max_tier_nominal_transfer_pressure_ratio": {
          "$ref": "#/$defs/nullableNumber"
        },
        "max_tier_contention_adjusted_transfer_pressure_ratio": {
          "$ref": "#/$defs/nullableNumber"
        },
        "max_tier_movement_energy_share": {
          "$ref": "#/$defs/nullableNumber"
        },
        "max_tier_system_energy_share": {
          "$ref": "#/$defs/nullableNumber"
        },
        "contention_bandwidth_saturation_tier": {
          "type": ["string", "null"]
        },
        "max_tier_contention_bandwidth_utilization": {
          "$ref": "#/$defs/nullableNumber"
        },
        "min_tier_contention_bandwidth_headroom_ratio": {
          "$ref": "#/$defs/nullableNumber"
        },
        "transfer_to_compute_time_ratio": {
          "$ref": "#/$defs/nullableNumber"
        },
        "contention_adjusted_transfer_to_compute_time_ratio": {
          "$ref": "#/$defs/nullableNumber"
        }
      }
    },
    "groupedMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["group", "artifacts", "decision_scorecard", "best"],
      "properties": {
        "group": {
          "type": "string"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "decision_scorecard": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "artifact_id",
              "score_explanation",
              "best_use",
              "score"
            ],
            "properties": {
              "artifact_id": {
                "type": "string"
              },
              "score_explanation": {
                "$ref": "#/$defs/scoreExplanation"
              },
              "best_use": {
                "type": "string"
              },
              "score": {
                "type": "number"
              }
            }
          }
        },
        "best": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["metric", "direction", "artifact_id", "value"],
            "properties": {
              "metric": {
                "type": "string"
              },
              "direction": {
                "type": "string"
              },
              "artifact_id": {
                "type": ["string", "null"]
              },
              "value": {
                "$ref": "#/$defs/nullableNumber"
              }
            }
          }
        }
      }
    }
  }
}
