{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://photonicbench.local/schemas/photonic-bench-report-v1.schema.json",
  "title": "PhotonicBench report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "benchmark",
    "workload",
    "model_inputs",
    "local_model",
    "published_reference",
    "calibration_fit",
    "assumptions",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "photonic-bench-report-v1"
    },
    "benchmark": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description"],
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"}
      }
    },
    "workload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "shape", "macs", "equivalent_ops", "output_elements"],
      "properties": {
        "type": {"const": "matmul"},
        "shape": {
          "type": "object",
          "additionalProperties": false,
          "required": ["m", "k", "n"],
          "properties": {
            "m": {"type": "integer", "minimum": 1},
            "k": {"type": "integer", "minimum": 1},
            "n": {"type": "integer", "minimum": 1}
          }
        },
        "macs": {"type": "integer", "minimum": 1},
        "equivalent_ops": {"type": "integer", "minimum": 1},
        "output_elements": {"type": "integer", "minimum": 1}
      }
    },
    "model_inputs": {
      "type": "object",
      "required": ["device", "execution", "system", "timing", "noise"],
      "additionalProperties": true,
      "properties": {
        "device": {
          "type": "object",
          "required": [
            "optical_mac_energy_fj",
            "laser_wall_plug_efficiency",
            "photodetector_energy_fj_per_sample",
            "adc",
            "dac",
            "vector_dac",
            "weight_dac"
          ],
          "additionalProperties": true,
          "properties": {
            "optical_mac_energy_fj": {"type": "number", "minimum": 0},
            "laser_wall_plug_efficiency": {
              "type": "number",
              "exclusiveMinimum": 0,
              "maximum": 1
            },
            "photodetector_energy_fj_per_sample": {
              "type": "number",
              "minimum": 0
            },
            "adc": {"$ref": "#/$defs/converter"},
            "dac": {"$ref": "#/$defs/converter"},
            "vector_dac": {"$ref": "#/$defs/converter"},
            "weight_dac": {"$ref": "#/$defs/converter"}
          }
        },
        "execution": {
          "type": "object",
          "required": [
            "batch_size",
            "vector_reuse_factor",
            "weight_reuse_factor",
            "weight_stationary",
            "pipeline"
          ],
          "additionalProperties": true,
          "properties": {
            "batch_size": {"type": "integer", "minimum": 1},
            "vector_reuse_factor": {"type": "integer", "minimum": 1},
            "weight_reuse_factor": {"type": "integer", "minimum": 1},
            "weight_stationary": {"type": "boolean"},
            "pipeline": {
              "type": "object",
              "required": ["stages", "cycle_time_ns"],
              "additionalProperties": true,
              "properties": {
                "stages": {"type": "integer", "minimum": 1},
                "cycle_time_ns": {
                  "type": ["number", "null"],
                  "exclusiveMinimum": 0
                }
              }
            }
          }
        },
        "system": {"$ref": "#/$defs/systemInputs"},
        "timing": {
          "type": "object",
          "required": [
            "optical_latency_ns",
            "adc_latency_ns",
            "dac_latency_ns"
          ],
          "additionalProperties": true,
          "properties": {
            "optical_latency_ns": {"type": "number", "minimum": 0},
            "adc_latency_ns": {"type": "number", "minimum": 0},
            "dac_latency_ns": {"type": "number", "minimum": 0}
          }
        },
        "noise": {
          "type": "object",
          "required": [
            "phase_noise_rad_rms",
            "drift_rad_per_second",
            "integration_time_ns"
          ],
          "additionalProperties": true,
          "properties": {
            "phase_noise_rad_rms": {"type": "number", "minimum": 0},
            "drift_rad_per_second": {"type": "number", "minimum": 0},
            "integration_time_ns": {"type": "number", "minimum": 0}
          }
        }
      }
    },
    "local_model": {
      "type": "object",
      "required": [
        "conversion_counts",
        "memory_traffic",
        "system",
        "energy",
        "timing",
        "noise"
      ],
      "additionalProperties": true,
      "properties": {
        "conversion_counts": {
          "type": "object",
          "required": [
            "adc_conversions",
            "vector_dac_conversions",
            "weight_dac_conversions",
            "dac_conversions"
          ],
          "additionalProperties": true,
          "properties": {
            "adc_conversions": {"type": "integer", "minimum": 0},
            "vector_dac_conversions": {"type": "integer", "minimum": 0},
            "weight_dac_conversions": {"type": "integer", "minimum": 0},
            "dac_conversions": {"type": "integer", "minimum": 0}
          }
        },
        "memory_traffic": {
          "type": "object",
          "required": [
            "vector_operand_read_bytes",
            "weight_operand_read_bytes",
            "output_write_bytes",
            "total_interface_bytes",
            "macs_per_byte",
            "equivalent_ops_per_byte",
            "note"
          ],
          "additionalProperties": true,
          "properties": {
            "vector_operand_read_bytes": {"type": "integer", "minimum": 0},
            "weight_operand_read_bytes": {"type": "integer", "minimum": 0},
            "output_write_bytes": {"type": "integer", "minimum": 0},
            "total_interface_bytes": {"type": "integer", "minimum": 0},
            "macs_per_byte": {"type": "number", "minimum": 0},
            "equivalent_ops_per_byte": {"type": "number", "minimum": 0},
            "note": {"type": "string"}
          }
        },
        "system": {"$ref": "#/$defs/systemResult"},
        "energy": {
          "type": "object",
          "required": [
            "optical_compute_pj",
            "laser_electrical_pj",
            "detector_pj",
            "adc_pj",
            "vector_dac_pj",
            "weight_dac_pj",
            "dac_pj",
            "total_pj",
            "energy_per_mac_pj",
            "energy_per_op_pj",
            "peripheral_share"
          ],
          "additionalProperties": true,
          "properties": {
            "optical_compute_pj": {"type": "number", "minimum": 0},
            "laser_electrical_pj": {"type": "number", "minimum": 0},
            "detector_pj": {"type": "number", "minimum": 0},
            "adc_pj": {"type": "number", "minimum": 0},
            "vector_dac_pj": {"type": "number", "minimum": 0},
            "weight_dac_pj": {"type": "number", "minimum": 0},
            "dac_pj": {"type": "number", "minimum": 0},
            "total_pj": {"type": "number", "minimum": 0},
            "energy_per_mac_pj": {"type": "number", "minimum": 0},
            "energy_per_op_pj": {"type": "number", "minimum": 0},
            "peripheral_share": {"type": "number", "minimum": 0}
          }
        },
        "timing": {
          "type": "object",
          "required": [
            "optical_latency_ns",
            "adc_latency_ns",
            "dac_latency_ns",
            "total_latency_ns",
            "pipeline_stages",
            "pipeline_cycle_time_ns",
            "batch_latency_ns",
            "steady_state_operations_per_second",
            "steady_state_equivalent_ops_per_second"
          ],
          "additionalProperties": true,
          "properties": {
            "optical_latency_ns": {"type": "number", "minimum": 0},
            "adc_latency_ns": {"type": "number", "minimum": 0},
            "dac_latency_ns": {"type": "number", "minimum": 0},
            "total_latency_ns": {"type": "number", "minimum": 0},
            "pipeline_stages": {"type": "integer", "minimum": 1},
            "pipeline_cycle_time_ns": {"type": "number", "minimum": 0},
            "batch_latency_ns": {"type": "number", "minimum": 0},
            "steady_state_operations_per_second": {
              "type": "number",
              "minimum": 0
            },
            "steady_state_equivalent_ops_per_second": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "noise": {
          "type": "object",
          "required": [
            "quantization_snr_db",
            "quantization_rms",
            "phase_noise_rad_rms",
            "drift_rms_rad",
            "estimated_relative_error_rms"
          ],
          "additionalProperties": true,
          "properties": {
            "quantization_snr_db": {"type": "number"},
            "quantization_rms": {"type": "number", "minimum": 0},
            "phase_noise_rad_rms": {"type": "number", "minimum": 0},
            "drift_rms_rad": {"type": "number", "minimum": 0},
            "estimated_relative_error_rms": {"type": "number", "minimum": 0}
          }
        }
      }
    },
    "published_reference": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source_type",
            "provenance",
            "reported",
            "derived_unit_conversions",
            "source_quality",
            "separation_note"
          ],
          "properties": {
            "source_type": {"const": "published_calibration"},
            "provenance": {"type": ["object", "null"]},
            "reported": {"type": "object"},
            "derived_unit_conversions": {"type": "object"},
            "source_quality": {
              "oneOf": [
                {"type": "null"},
                {"$ref": "#/$defs/sourceQuality"}
              ]
            },
            "separation_note": {"type": "string"}
          }
        }
      ]
    },
    "calibration_fit": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "required": [
            "target",
            "target_source",
            "target_total_energy_pj",
            "fitted_parameter",
            "objective",
            "pre_fit_total_energy_pj",
            "post_fit_total_energy_pj",
            "absolute_error_pj",
            "relative_error",
            "assumptions"
          ],
          "additionalProperties": true
        }
      ]
    },
    "assumptions": {
      "type": "array",
      "items": {"type": "string"}
    },
    "provenance": {
      "type": ["object", "null"]
    }
  },
  "$defs": {
    "converter": {
      "type": "object",
      "required": ["bits", "energy_pj_per_conversion"],
      "additionalProperties": true,
      "properties": {
        "bits": {"type": "integer", "minimum": 1},
        "energy_pj_per_conversion": {"type": "number", "minimum": 0}
      }
    },
    "systemInputs": {
      "type": "object",
      "required": [
        "profile",
        "profile_overrides",
        "memory_timing_mode",
        "contention",
        "sram",
        "intermediate",
        "off_chip"
      ],
      "additionalProperties": false,
      "properties": {
        "profile": {"type": "string"},
        "profile_overrides": {
          "type": "array",
          "items": {"type": "string"}
        },
        "memory_timing_mode": {"enum": ["overlapped", "serialized"]},
        "contention": {"$ref": "#/$defs/systemContentionInputs"},
        "sram": {"$ref": "#/$defs/systemTierInputs"},
        "intermediate": {"$ref": "#/$defs/systemTierInputs"},
        "off_chip": {"$ref": "#/$defs/systemTierInputs"}
      }
    },
    "systemContentionInputs": {
      "type": "object",
      "required": [
        "shared_bandwidth_clients",
        "arbitration_efficiency",
        "calibration_overhead_fraction"
      ],
      "additionalProperties": false,
      "properties": {
        "shared_bandwidth_clients": {"type": "number", "exclusiveMinimum": 0},
        "arbitration_efficiency": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "calibration_overhead_fraction": {"type": "number", "minimum": 0}
      }
    },
    "sourceQuality": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_reference",
        "source_doi",
        "reported_metrics",
        "local_surrogate_type",
        "coverage",
        "confidence_grade",
        "notes",
        "note"
      ],
      "properties": {
        "source_reference": {"type": ["string", "null"]},
        "source_doi": {"type": ["string", "null"]},
        "reported_metrics": {
          "type": "array",
          "items": {"type": "string"}
        },
        "local_surrogate_type": {"type": "string"},
        "coverage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["throughput", "energy", "accuracy", "area", "precision"],
          "properties": {
            "throughput": {"type": "string"},
            "energy": {"type": "string"},
            "accuracy": {"type": "string"},
            "area": {"type": "string"},
            "precision": {"type": "string"}
          }
        },
        "confidence_grade": {"enum": ["A", "B", "C", "D"]},
        "notes": {
          "type": "array",
          "items": {"type": "string"}
        },
        "note": {"type": "string"}
      }
    },
    "systemTierInputs": {
      "type": "object",
      "required": [
        "read_energy_pj_per_byte",
        "write_energy_pj_per_byte",
        "bandwidth_bytes_per_ns",
        "read_fraction",
        "write_fraction"
      ],
      "additionalProperties": false,
      "properties": {
        "read_energy_pj_per_byte": {"type": "number", "minimum": 0},
        "write_energy_pj_per_byte": {"type": "number", "minimum": 0},
        "bandwidth_bytes_per_ns": {"type": "number", "exclusiveMinimum": 0},
        "read_fraction": {"type": "number", "minimum": 0, "maximum": 1},
        "write_fraction": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "systemResult": {
      "type": "object",
      "required": [
        "profile",
        "profile_overrides",
        "memory_timing_mode",
        "contention",
        "tiers",
        "local_compute_and_conversion_energy_pj",
        "total_movement_energy_pj",
        "total_system_energy_pj",
        "system_energy_per_mac_pj",
        "system_energy_per_op_pj",
        "movement_energy_share",
        "total_hierarchy_bytes",
        "hierarchy_equivalent_ops_per_byte",
        "movement_energy_per_hierarchy_byte_pj",
        "sram_traffic_share",
        "intermediate_traffic_share",
        "off_chip_traffic_share",
        "dominant_traffic_tier",
        "dominant_movement_energy_tier",
        "nominal_memory_bottleneck_tier",
        "contention_memory_bottleneck_tier",
        "max_tier_nominal_transfer_pressure_ratio",
        "max_tier_contention_adjusted_transfer_pressure_ratio",
        "max_tier_movement_energy_share",
        "max_transfer_time_ns",
        "serial_transfer_time_ns",
        "effective_transfer_time_ns",
        "contention_bandwidth_derate_factor",
        "contention_adjusted_max_transfer_time_ns",
        "contention_adjusted_serial_transfer_time_ns",
        "contention_adjusted_effective_transfer_time_ns",
        "calibration_adjusted_effective_transfer_time_ns",
        "calibration_guardband_time_ns",
        "contention_transfer_overhead_fraction",
        "total_transfer_overhead_fraction",
        "effective_loaded_bandwidth_bytes_per_ns",
        "contention_adjusted_loaded_bandwidth_bytes_per_ns",
        "transfer_to_compute_time_ratio",
        "bandwidth_limited_batch_latency_ns",
        "bandwidth_pressure_ratio",
        "bandwidth_limited_equivalent_ops_per_second",
        "bandwidth_limited_tier",
        "contention_adjusted_batch_latency_ns",
        "contention_adjusted_transfer_to_compute_time_ratio",
        "contention_pressure_ratio",
        "contention_adjusted_equivalent_ops_per_second",
        "contention_limited_tier",
        "note"
      ],
      "additionalProperties": false,
      "properties": {
        "profile": {"type": "string"},
        "profile_overrides": {
          "type": "array",
          "items": {"type": "string"}
        },
        "memory_timing_mode": {"enum": ["overlapped", "serialized"]},
        "contention": {"$ref": "#/$defs/systemContentionInputs"},
        "tiers": {
          "type": "object",
          "required": ["sram", "intermediate", "off_chip"],
          "additionalProperties": false,
          "properties": {
            "sram": {"$ref": "#/$defs/systemTierResult"},
            "intermediate": {"$ref": "#/$defs/systemTierResult"},
            "off_chip": {"$ref": "#/$defs/systemTierResult"}
          }
        },
        "local_compute_and_conversion_energy_pj": {"type": "number", "minimum": 0},
        "total_movement_energy_pj": {"type": "number", "minimum": 0},
        "total_system_energy_pj": {"type": "number", "minimum": 0},
        "system_energy_per_mac_pj": {"type": "number", "minimum": 0},
        "system_energy_per_op_pj": {"type": "number", "minimum": 0},
        "movement_energy_share": {"type": "number", "minimum": 0, "maximum": 1},
        "total_hierarchy_bytes": {"type": "number", "minimum": 0},
        "hierarchy_equivalent_ops_per_byte": {"type": "number", "minimum": 0},
        "movement_energy_per_hierarchy_byte_pj": {
          "type": "number",
          "minimum": 0
        },
        "sram_traffic_share": {"type": "number", "minimum": 0, "maximum": 1},
        "intermediate_traffic_share": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "off_chip_traffic_share": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "dominant_traffic_tier": {"type": "string"},
        "dominant_movement_energy_tier": {"type": "string"},
        "nominal_memory_bottleneck_tier": {"type": "string"},
        "contention_memory_bottleneck_tier": {"type": "string"},
        "max_tier_nominal_transfer_pressure_ratio": {
          "type": "number",
          "minimum": 0
        },
        "max_tier_contention_adjusted_transfer_pressure_ratio": {
          "type": "number",
          "minimum": 0
        },
        "max_tier_movement_energy_share": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "max_transfer_time_ns": {"type": "number", "minimum": 0},
        "serial_transfer_time_ns": {"type": "number", "minimum": 0},
        "effective_transfer_time_ns": {"type": "number", "minimum": 0},
        "contention_bandwidth_derate_factor": {
          "type": "number",
          "minimum": 0
        },
        "contention_adjusted_max_transfer_time_ns": {
          "type": "number",
          "minimum": 0
        },
        "contention_adjusted_serial_transfer_time_ns": {
          "type": "number",
          "minimum": 0
        },
        "contention_adjusted_effective_transfer_time_ns": {
          "type": "number",
          "minimum": 0
        },
        "calibration_adjusted_effective_transfer_time_ns": {
          "type": "number",
          "minimum": 0
        },
        "calibration_guardband_time_ns": {"type": "number", "minimum": 0},
        "contention_transfer_overhead_fraction": {"type": "number", "minimum": 0},
        "total_transfer_overhead_fraction": {"type": "number", "minimum": 0},
        "effective_loaded_bandwidth_bytes_per_ns": {
          "type": "number",
          "minimum": 0
        },
        "contention_adjusted_loaded_bandwidth_bytes_per_ns": {
          "type": "number",
          "minimum": 0
        },
        "transfer_to_compute_time_ratio": {"type": "number", "minimum": 0},
        "bandwidth_limited_batch_latency_ns": {"type": "number", "minimum": 0},
        "bandwidth_pressure_ratio": {"type": "number", "minimum": 0},
        "bandwidth_limited_equivalent_ops_per_second": {
          "type": "number",
          "minimum": 0
        },
        "bandwidth_limited_tier": {"type": "string"},
        "contention_adjusted_batch_latency_ns": {
          "type": "number",
          "minimum": 0
        },
        "contention_adjusted_transfer_to_compute_time_ratio": {
          "type": "number",
          "minimum": 0
        },
        "contention_pressure_ratio": {"type": "number", "minimum": 0},
        "contention_adjusted_equivalent_ops_per_second": {
          "type": "number",
          "minimum": 0
        },
        "contention_limited_tier": {"type": "string"},
        "note": {"type": "string"}
      }
    },
    "systemTierResult": {
      "type": "object",
      "required": [
        "name",
        "read_bytes",
        "write_bytes",
        "total_bytes",
        "read_energy_pj",
        "write_energy_pj",
        "total_energy_pj",
        "bandwidth_bytes_per_ns",
        "effective_bandwidth_bytes_per_ns",
        "transfer_time_ns",
        "contention_adjusted_transfer_time_ns",
        "read_fraction",
        "write_fraction",
        "calibration_adjusted_transfer_time_ns",
        "traffic_share",
        "movement_energy_share",
        "nominal_transfer_share",
        "contention_adjusted_transfer_share",
        "nominal_transfer_pressure_ratio",
        "contention_adjusted_transfer_pressure_ratio"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string"},
        "read_bytes": {"type": "number", "minimum": 0},
        "write_bytes": {"type": "number", "minimum": 0},
        "total_bytes": {"type": "number", "minimum": 0},
        "read_energy_pj": {"type": "number", "minimum": 0},
        "write_energy_pj": {"type": "number", "minimum": 0},
        "total_energy_pj": {"type": "number", "minimum": 0},
        "bandwidth_bytes_per_ns": {"type": "number", "exclusiveMinimum": 0},
        "effective_bandwidth_bytes_per_ns": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "transfer_time_ns": {"type": "number", "minimum": 0},
        "contention_adjusted_transfer_time_ns": {
          "type": "number",
          "minimum": 0
        },
        "read_fraction": {"type": "number", "minimum": 0, "maximum": 1},
        "write_fraction": {"type": "number", "minimum": 0, "maximum": 1},
        "calibration_adjusted_transfer_time_ns": {
          "type": "number",
          "minimum": 0
        },
        "traffic_share": {"type": "number", "minimum": 0, "maximum": 1},
        "movement_energy_share": {"type": "number", "minimum": 0, "maximum": 1},
        "nominal_transfer_share": {"type": "number", "minimum": 0},
        "contention_adjusted_transfer_share": {"type": "number", "minimum": 0},
        "nominal_transfer_pressure_ratio": {"type": "number", "minimum": 0},
        "contention_adjusted_transfer_pressure_ratio": {
          "type": "number",
          "minimum": 0
        }
      }
    }
  }
}
